<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.trainingcourses.TrainingCoursesViewmodel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tbStartTraining"
                android:layout_width="match_parent"
                android:layout_height="?actionBarSize"
                app:layout_scrollFlags="snap"
                app:title=" ">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Welcome!"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_6sdp"

                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{vm.employeeName}"
                            android:textAllCaps="false"
                            android:textColor="@color/textColorBlackBold"
                            android:textSize="@dimen/_8sdp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!--                    <ImageView-->
                    <!--                        android:id="@+id/logoutbtn"-->
                    <!--                        android:layout_width="25dp"-->
                    <!--                        android:layout_height="25dp"-->
                    <!--                        android:layout_gravity="end"-->
                    <!--                        android:layout_marginRight="20dp"-->
                    <!--                        android:src="@drawable/baseline_logout"></ImageView>-->


                    <!--                    <ImageView-->
                    <!--                        android:id="@+id/notificbtn"-->
                    <!--                        android:layout_width="25dp"-->
                    <!--                        android:layout_height="25dp"-->
                    <!--                        android:layout_gravity="end"-->
                    <!--                        android:layout_marginRight="20dp"-->
                    <!--                        android:src="@drawable/notifications"></ImageView>-->


                    <!-- <ImageView
                         android:id="@+id/backtodashbtn"
                         android:layout_width="30dp"
                         android:layout_height="30dp"
                         android:background="@drawable/circularavtararrow"
                         android:padding="4dp"
                         android:src="@drawable/arrow_back"></ImageView>
 -->
                    <!-- <TextView
                         android:id="@+id/toolbar_title"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:layout_marginStart="120dp"
                         android:text="My Courses"

                         android:textColor="@color/textColorBlackBold"
                         android:textSize="@dimen/_14sdp"
                         android:textStyle="bold" />-->

                </LinearLayout>


            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="My Courses"
            android:textColor="@color/textColorBlackBold"
            android:textSize="@dimen/_14sdp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/appbar" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/seachview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10sp"
            android:layout_marginEnd="@dimen/_16sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:background="@drawable/searchstyle"
            android:paddingTop="7dp"
            android:paddingBottom="9dp"
            app:iconifiedByDefault="false"
            app:layout_constraintBottom_toTopOf="@id/recyclerView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar_title"
            app:queryBackground="@android:color/transparent"
            app:queryHint="Search Course" />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="200dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/seachview"
            app:trainingCourseListener="@{vm.trainingCourseViewListeners}"
            app:trainingCourseAdapter="@{vm.adapterV2}" />

        <!--app:myTrainingCoursesViewListener="@{vm.trainingCourseViewListeners}"
        app:setTrainingCoursesRecyclerAdapter="@{vm.adapter}"-->

        <androidx.core.widget.ContentLoadingProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="176dp"
            android:visibility="@{vm.isLoading}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="@+id/recyclerView"
            app:layout_constraintTop_toBottomOf="@+id/seachview" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

