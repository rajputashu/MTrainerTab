<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.reports.ReportsViewmodel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:fillViewport="true"
            android:layout_height="match_parent">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:fillViewport="true"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:orientation="horizontal"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_height="wrap_content">


                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_date_from"
                            android:gravity="center_vertical"
                            android:layout_marginStart="20dp"
                            android:drawableEnd="@drawable/ic_training_calendar"
                            android:textSize="@dimen/_10ssp" />

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="140dp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginRight="@dimen/_1sdp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginLeft="10dp"
                            android:gravity="center_vertical"
                            android:paddingLeft="5dp"
                            android:background="@drawable/rectangle_border_grey"
                            android:layout_marginBottom="@dimen/_4sdp"
                            android:id="@+id/relative37">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@color/white"
                                app:layout_constraintTop_toTopOf="parent"
                                android:backgroundTint="@color/white"
                                android:id="@+id/sp_year"
                                android:textColor="@color/black"
                                android:text="@{vm.selectedstartdate}"
                                android:textAlignment="textStart"
                                android:textSize="@dimen/_8ssp"/>


                        </androidx.appcompat.widget.LinearLayoutCompat>


                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginStart="@dimen/_30sdp"
                            android:layout_marginEnd="10dp"
                            android:gravity="center_vertical"
                            android:drawableEnd="@drawable/ic_training_calendar"
                            android:text="@string/string_date_to"
                            android:textSize="@dimen/_10ssp" />

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="140dp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginRight="@dimen/_1sdp"
                            android:layout_marginStart="10dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginLeft="10dp"
                            android:gravity="center_vertical"
                            android:paddingLeft="5dp"
                            android:background="@drawable/rectangle_border_grey"
                            android:layout_marginBottom="@dimen/_4sdp"
                            android:id="@+id/relative38">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:backgroundTint="@color/white"
                                android:text="@{vm.selectedenddate}"
                                android:id="@+id/sp_month"
                                android:textColor="@color/black"
                                android:textAlignment="textStart"
                                android:textSize="@dimen/_8ssp"/>


                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="230dp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginRight="@dimen/_1sdp"
                            android:layout_marginLeft="20dp"
                            android:background="@drawable/rectangle_border_grey"
                            android:layout_marginBottom="@dimen/_4sdp"
                            android:id="@+id/relative143143">
                            <com.jaiselrahman.hintspinner.HintSpinner
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:backgroundTint="@color/white"
                                android:id="@+id/sp_branchname"
                                android:textColor="@color/black"
                                branchtabEntriesUnits="@{vm.branchList}"
                                setSpinnerItemSelectorMyUnitsTab="@{vm.branchViewListeners}"
                                android:textAlignment="textStart"
                                android:textSize="@dimen/_8ssp"/>


                        </androidx.appcompat.widget.LinearLayoutCompat>


                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="100dp"
                            android:textAlignment="center"
                            android:singleLine="false"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:onClick="@{vm::applyclick}"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_8ssp"
                            android:text="Apply"/>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="200dp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginRight="@dimen/_1sdp"
                            android:layout_marginLeft="20dp"
                            android:background="@drawable/rectangle_border_grey"
                            android:layout_marginBottom="@dimen/_4sdp"
                            android:id="@+id/rv_filter">
                            <com.jaiselrahman.hintspinner.HintSpinner
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:backgroundTint="@color/white"
                                android:id="@+id/sp_filter"
                                android:textColor="@color/black"
                                filterEntries="@{vm.filterlist}"
                                setSpinnerItemSelectorInductionFilter="@{vm.inductionFilterViewListeners}"
                                android:textAlignment="textStart"
                                android:textSize="@dimen/_8ssp"/>


                        </androidx.appcompat.widget.LinearLayoutCompat>


                        <!-- <androidx.appcompat.widget.AppCompatTextView
                             android:layout_width="wrap_content"
                             android:singleLine="false"
                             android:layout_marginLeft="20dp"
                             android:layout_height="@dimen/_19sdp"
                             android:textColor="@color/black"
                             android:textSize="@dimen/_8ssp"
                             android:text="Course Not Started"/>
                         <CheckBox
                             android:layout_width="30dp"
                             android:id="@+id/cb_coursenotfound"
                             android:layout_height="30dp"/>-->


                    </LinearLayout>


                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/white"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_marginBottom="1.5dp"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="130dp"
                            android:textAlignment="center"
                            android:singleLine="false"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="DOJ"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="160dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:singleLine="false"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Zone Name"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="180dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:singleLine="false"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Region Name"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:singleLine="false"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Branch Name"/>
                        <!--
                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:layout_width="150dp"
                                            android:layout_marginLeft="@dimen/_1sdp"
                                            android:textAlignment="center"
                                            android:layout_marginEnd="@dimen/_1sdp"
                                            android:singleLine="false"
                                            android:layout_height="@dimen/_15sdp"
                                            android:gravity="center"
                                            android:background="@drawable/button_white_border"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_8ssp"
                                            android:text="Present Days"/>
                        -->

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:singleLine="false"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Employee Name"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:singleLine="false"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Employee No"/>

                        <!--
                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:layout_width="180dp"
                                            android:layout_marginLeft="@dimen/_1sdp"
                                            android:textAlignment="center"
                                            android:singleLine="false"
                                            android:layout_marginEnd="@dimen/_1sdp"
                                            android:layout_height="@dimen/_15sdp"
                                            android:gravity="center"
                                            android:background="@drawable/button_white_border"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_8ssp"
                                            android:text="Van Training KM"/>
                        -->

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:singleLine="false"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Primary Con.No"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:singleLine="false"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="Site Name"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:id="@+id/onclick"
                            android:textAlignment="center"
                            android:singleLine="false"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="IsLogin"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="150dp"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/_1sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:singleLine="false"
                            android:gravity="center"
                            android:background="@drawable/button_white_border"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="CourseStatus"/>


                    </androidx.appcompat.widget.LinearLayoutCompat>



                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:background="@color/white"
                        android:orientation="vertical">
                        <!--  android:background="@color/lighter_grey"-->
                        <androidx.recyclerview.widget.RecyclerView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:id="@+id/rv_Calendar_Rota"
                            app:setmyemployeereportslistener="@{vm.trainingCourseViewListeners}"
                            app:setmyreportsemployeeadapter="@{vm.adapter}">
                        </androidx.recyclerview.widget.RecyclerView>

                        <!--
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:id="@+id/tv_No_Rota"
                                        android:textSize="@dimen/_8ssp"
                                        android:text="Data not Found"
                                        android:background="@color/lighter_grey"
                                        android:gravity="center"
                                        android:textAlignment="center"
                                        android:textColor="@color/black"/>
                        -->
                    </androidx.appcompat.widget.LinearLayoutCompat>


                </LinearLayout>

            </HorizontalScrollView>

        </ScrollView>



        <androidx.core.widget.ContentLoadingProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_gravity="center"
            android:visibility="@{vm.isLoading}" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>