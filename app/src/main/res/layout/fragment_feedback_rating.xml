<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.feedback.FeedbackActivityViewModel" />
    </data>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/DarkBlue"
        android:orientation="vertical">
        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/colorWhite"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginLeft="@dimen/_15sdp"
            android:text="CLIENT MODE"/>



        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_15sdp"
            app:cardCornerRadius="@dimen/_6sdp"
            android:background="@color/colorWhite">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:orientation="horizontal">

                        <com.droidcommons.views.roundedimageview.RoundedImageView
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_40sdp"
                            app:fabCustomSize="@dimen/_40sdp"
                            app:borderWidth="0dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            app:srcCompat="@drawable/ic_unit_name" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:orientation="vertical">
                        <androidx.appcompat.widget.AppCompatTextView

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Eldico housing &amp; industries LTD."
                            android:textColor="@color/textColorBlackBold"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold"
                            android:id="@+id/feedback_ratting_unit_name"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Unit Name"
                            android:textColor="@color/colorTextGrey"
                            android:textSize="@dimen/_10ssp"
                            android:textStyle="bold" />
                        <View
                            android:layout_width="wrap_content"
                            android:background="@color/Grey"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/_15sdp"
                            android:layout_height="@dimen/_1sdp"/>

                    </LinearLayout>


                </LinearLayout>






                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:orientation="horizontal">

                        <com.droidcommons.views.roundedimageview.RoundedImageView
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_40sdp"
                            app:fabCustomSize="@dimen/_40sdp"
                            app:borderWidth="0dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            app:srcCompat="@drawable/ic_client_name" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:orientation="vertical">
                        <androidx.appcompat.widget.AppCompatTextView

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Mr. Dinesh Chandra Chaturvedi"
                            android:textColor="@color/textColorBlackBold"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold"
                            android:id="@+id/feedback_ratting_name"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Client Name"
                            android:textColor="@color/colorTextGrey"
                            android:textSize="@dimen/_10ssp"
                            android:textStyle="bold" />
                        <View
                            android:layout_width="wrap_content"
                            android:background="@color/Grey"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/_15sdp"
                            android:layout_height="@dimen/_1sdp"/>

                    </LinearLayout>


                </LinearLayout>




                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:orientation="horizontal">

                        <com.droidcommons.views.roundedimageview.RoundedImageView
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_40sdp"
                            app:fabCustomSize="@dimen/_40sdp"
                            app:borderWidth="0dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            app:srcCompat="@drawable/ic_mobile" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:orientation="vertical">
                        <androidx.appcompat.widget.AppCompatTextView

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="+91 8327984076"
                            android:textColor="@color/textColorBlackBold"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold"
                            android:id="@+id/feedback_ratting_number"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Mobile Number"
                            android:textColor="@color/colorTextGrey"
                            android:textSize="@dimen/_10ssp"
                            android:textStyle="bold" />
                        <View
                            android:layout_width="wrap_content"
                            android:background="@color/Grey"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/_15sdp"
                            android:layout_height="@dimen/_1sdp"/>

                    </LinearLayout>


                </LinearLayout>



                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/_45sdp"
                    android:orientation="vertical">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/_16ssp"
                        android:layout_marginLeft="@dimen/_5sdp"
                        android:textColor="@color/textColorBlackBold"
                        android:text="Your FeedBack" />

                    <androidx.appcompat.widget.AppCompatRatingBar
                        android:id="@+id/feedback_ratting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:progressTint="#ffc107" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:weightSum="2"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/_16ssp"
                            android:layout_weight="1"
                            android:layout_marginLeft="@dimen/_5sdp"
                            android:textColor="@color/colorTextGrey"
                            android:text="Not Good" />
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:textSize="@dimen/_16ssp"
                            android:layout_marginLeft="@dimen/_5sdp"
                            android:textColor="@color/colorTextGrey"
                            android:text="Excellent" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</layout>