<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.attendancemodule.TrainingPicAndSignatureViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorWhite">
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/textColorBlackBold"
                android:textSize="@dimen/_16ssp"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="center"
                android:id="@+id/user_name"
                android:layout_marginBottom="@dimen/_10sdp"
                android:text="Manish"/>
        </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorWhite"
        android:weightSum="2"
        android:orientation="vertical">


        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight=".9"
            android:orientation="vertical">



            <androidx.camera.view.PreviewView
                 android:layout_width="match_parent"
                 android:id="@+id/imagePreview"
               android:visibility="gone"
              android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_30sdp"

                 android:layout_height="@dimen/_170sdp">
                 <ImageView
                     android:layout_width="match_parent"
                     android:id="@+id/photoPreView"
                     android:layout_height="match_parent"/>

             </androidx.camera.view.PreviewView>





            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_gravity="center"
                android:id="@+id/takePhotoText"
                android:text="TAKE PHOTO"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:textColor="@color/textColorBlackBold"
                android:textSize="@dimen/_15ssp" />


            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_100sdp"
                android:layout_height="@dimen/_100sdp"
                android:id="@+id/clickPhoto"
                android:layout_gravity="center|top"
                android:layout_weight="1"

                android:src="@drawable/ic_camera" />

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_8sdp"
                android:layout_marginRight="@dimen/_8sdp"
                android:backgroundTint="@color/red"
                android:gravity="bottom"
                android:textColor="@color/colorWhite"
                android:layout_marginBottom="@dimen/_5sdp"
                android:layout_gravity="center"
                android:visibility="invisible"
                android:id="@+id/retake"
                android:text="retake"
                android:textSize="@dimen/_14ssp"/>







        </androidx.appcompat.widget.LinearLayoutCompat>
        <View
            android:layout_width="wrap_content"
            android:background="@color/black"
            android:layout_gravity="center_horizontal"
            android:layout_height="@dimen/_1sdp"/>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1.1"
            android:layout_marginBottom="@dimen/_2sdp"
            android:orientation="vertical">


            <RelativeLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:background="@color/colorWhite"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dp"
                    android:layout_marginTop="20dp"
                    android:hint="Sign Here"
                    android:layout_centerInParent="true"
                    android:textColor="@color/colorTextGrey"
                    android:textSize="20dp"
                    android:typeface="serif" />


                <com.droidcommons.views.ink.InkView
                    android:id="@+id/inkSignature"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignParentBottom="true"
                    android:backgroundTint="@color/colorWhite"
                    android:background="@color/colorWhite"
                    app:addInkListeners="@{vm.listener}"
                    app:inkFlags="interpolation|responsiveWeight" />
<!--

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/_10sdp"
                    android:backgroundTint="@color/colorTextGrey"
                    android:background="@drawable/ic_round_circle"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:onClick="@{()->vm.onInkViewClear(inkSignature)}"
                    android:padding="@dimen/_8sdp"
                    android:visibility="@{vm.isSigned}"
                    app:srcCompat="@drawable/ic_clear" />


-->

                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_30sdp"
                    android:id="@+id/signButton"
                    android:layout_alignParentBottom="true"
                    android:layout_marginLeft="@dimen/_40sdp"
                    android:background="@color/colorLightRed"
                    android:onClick="@{()->vm.onAddSignatureContinue(inkSignature)}"
                    android:text="save"
                    android:textColor="@color/colorWhite"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:textSize="@dimen/_14ssp" />
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginRight="@dimen/_40sdp"
                    android:onClick="@{()->vm.onInkViewClear(inkSignature)}"
                    android:visibility="@{vm.isSigned}"
                    android:layout_marginBottom="@dimen/_10sdp"

                    android:background="@color/colorLightRed"
                    android:text="clear"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_14ssp" />






            </RelativeLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>


    </androidx.appcompat.widget.LinearLayoutCompat>
    </LinearLayout>


</layout>