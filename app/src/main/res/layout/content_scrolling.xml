<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>




    <RelativeLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/submodule_layout"
            android:layout_width="match_parent"
            android:layout_height="40dp">

            <RelativeLayout
                android:id="@+id/section"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:background="@drawable/drawable_background_3d"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:layout_centerVertical="true"
                    android:width="100dp"
                    android:background="@drawable/rounded_shape_text"
                    android:gravity="center_vertical"
                    android:text="SECTION"
                    android:textAlignment="center"
                    android:textColor="@color/colorWhite"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@+id/section"
                android:layout_weight="3"
                android:background="@drawable/sub_module_background"
                tools:ignore="ObsoleteLayoutParam">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:id="@+id/submodule_name"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:text="Physical Training- PT, Hurdle, Yoga"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    tools:ignore="HardcodedText" />
            </RelativeLayout>

            <TextView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="-20dp"
                android:layout_toEndOf="@+id/section"
                android:id="@+id/submodule_no"
                android:background="@drawable/drawable_circle_grey"
                android:gravity="center_vertical"
                android:text="1"
                android:textAlignment="center"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/video_layout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_55sdp"
            android:layout_below="@+id/submodule_layout">

            <RelativeLayout
                android:id="@+id/lecture"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:background="@drawable/drawable_lecture_bg"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:layout_centerVertical="true"
                    android:width="100dp"
                    android:id="@+id/lecture1_text"
                    android:gravity="center_vertical"
                    android:text="LECTURE 1"
                    android:textSize="13sp"
                    android:layout_marginStart="@dimen/_25sdp"
                    tools:ignore="HardcodedText" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@+id/lecture"
                android:layout_centerVertical="true"
                android:background="@drawable/drawable_lecture_content_bg"
                tools:ignore="ObsoleteLayoutParam">

                <TextView
                    android:id="@+id/subheading_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_25sdp"
                    android:ellipsize="end"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:singleLine="true"
                    android:text="Background"
                    android:textColor="#616161"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText,SpUsage" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/subheading_title"
                    android:layout_marginLeft="@dimen/_25sdp"
                    android:drawablePadding="@dimen/_5sdp"
                    android:id="@+id/duration"
                    android:drawableStart="@drawable/ic_theaters_black_18dp"
                    android:drawableTint="#bfbfbf"
                    android:text="Video - 00:00 mins"
                    android:textSize="@dimen/_12sdp"
                    tools:ignore="RtlHardcoded,SpUsage"
                    tools:targetApi="m" />

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_right_arrow"
                    android:tint="#616161"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/lecture1_subheader"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="-20dp"
                android:layout_toEndOf="@+id/lecture"
                android:gravity="center_vertical"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:background="@drawable/drawable_circle_light_grey">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_centerInParent="true"
                    android:layout_marginTop="1dp"
                    android:background="@drawable/drawable_circle_dot"
                    android:gravity="center_horizontal|center_vertical"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:ignore="ContentDescription" />

            </RelativeLayout>
            <TextView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="-20dp"
                android:visibility="gone"
                android:layout_toEndOf="@+id/lecture"
                android:background="@drawable/drawable_inner_circle"
                android:gravity="center_vertical"
                android:text="1"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </RelativeLayout>
    </RelativeLayout>


</layout>