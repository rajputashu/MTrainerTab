<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_8sdp"
        android:layout_marginRight="@dimen/_8sdp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">


            <com.droidcommons.views.roundedimageview.RoundedImageView
                android:id="@+id/ivTopicThumbnail"
                android:layout_width="@dimen/_55sdp"
                android:layout_height="@dimen/_55sdp"
                android:scaleType="fitXY"
                app:riv_border_color="@color/green"
                app:riv_border_width="@dimen/_2sdp"
                app:riv_oval="true" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_30sdp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/_40sdp"
                android:text="08"
                android:gravity="center"
                android:textColor="@color/colorWhite"
                app:chipBackgroundColor="@color/colorBlue"
                app:chipIcon="@drawable/ic_group_topic"
                app:iconEndPadding="-8dp"
                app:iconStartPadding="2dp"
                app:chipIconTint="@color/colorWhite"
                app:chipCornerRadius="@dimen/_4sdp"
                />

        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Topic"
            android:textColor="@color/black"
            android:textStyle="bold" />


    </LinearLayout>
</layout>