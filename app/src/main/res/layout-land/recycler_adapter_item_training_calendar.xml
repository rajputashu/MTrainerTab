<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.models.CalendarResponse.CalendarRotaResponse" />
        <import type="android.view.View"/>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.trainingcalendar.TrainingCalendarViewModel" />
    </data>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/lighter_grey"
        android:orientation="vertical">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:layout_marginLeft="@dimen/_8sdp"
            android:layout_marginRight="@dimen/_8sdp"
            android:layout_marginTop="0.5dp"
            android:layout_marginBottom="0.5dp"
            android:weightSum="8"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:id="@+id/position"
                android:background="@color/LightBlueGrey"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp" />
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.branch}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.site}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.estimatedStartDate}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.EstimatedEndDate}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.actualStartTime}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.actualEndtime}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginRight="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.status}"/>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>
</layout>