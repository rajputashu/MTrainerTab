<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.pretraining.PreTrainingReviewViewModel" />

    </data>



    <RelativeLayout
        android:layout_width="match_parent"
        android:background="@color/colorWhite"

        android:layout_height="match_parent">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:layout_marginTop="@dimen/_5sdp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_10ssp"
                    android:text="Training Not Done Due to :"
                    android:textColor="@color/black"
                    android:layout_margin="@dimen/_5sdp"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:id="@+id/taining_not_done"/>


                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/taining_not_done"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:id="@+id/rg_issue"
                    android:orientation="vertical">

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobilization Problem"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_1"
                        />

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Training Officer on leave"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_2"
                        />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver on leave"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_3"
                        />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weather Problem"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_4"
                        />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Van Issue"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_5"
                        />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance Issues"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_6"
                        />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Client permission"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_7"
                        />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Other issue if any "
                        android:textColor="@color/black"
                        android:textSize="@dimen/_7ssp"
                        android:id="@+id/rb_8"
                        />
                </RadioGroup>

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/other_isue"
                    android:layout_below="@+id/rg_issue"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:textColor="@color/black"
                    android:visibility="gone"
                    android:hint="Mention Issue"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="@dimen/_45sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:layout_below="@+id/other_isue"
                    android:layout_margin="@dimen/_5sdp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:textSize="@dimen/_10ssp"
                    android:id="@+id/ok_otherissue"
                    android:background="@color/red"
                    android:textColor="@color/colorWhite"
                    android:text="OK"/>

                <!--            android:onClick="@{vm.oncancel}"-->




            </RelativeLayout>

        </ScrollView>

    </RelativeLayout>

