<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View"/>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.attendancemodule.TrainingAttendanceViewModel" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:cardCornerRadius="@dimen/_8sdp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_4sdp"
            android:layout_marginTop="@dimen/_2sdp"
            android:layout_marginBottom="@dimen/_2sdp">
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_8sdp"
                android:text="Add Employee"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="@dimen/_10ssp"/>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <androidx.appcompat.widget.AppCompatImageButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginRight="@dimen/_10sdp"
                    android:backgroundTint="@color/Grey"
                    android:background="@drawable/ic_round_circle"
                    android:padding="@dimen/_4sdp"
                    app:srcCompat="@drawable/ic_clear"
                    android:id="@+id/close_btn"/>
                <EditText
                    android:layout_marginTop="@dimen/_6sdp"
                    android:id="@+id/et_employeeId"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="@dimen/_8sdp"
                    android:layout_marginRight="@dimen/_10sdp"
                    android:layout_height="?actionBarSize" />
                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/_8sdp"
                    android:paddingEnd="@dimen/_8sdp"
                    android:textSize="@dimen/_8ssp"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:gravity="center_vertical"
                    android:text="@{vm.empName.equals(``) ? `` : vm.empName}"
                    android:visibility="@{vm.empName.equals(``) ? View.GONE : View.VISIBLE}"/>

                <EditText
                    android:layout_marginTop="@dimen/_8sdp"
                    android:id="@+id/et_employee_name"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="@dimen/_8sdp"
                    android:layout_height="?actionBarSize"
                    android:hint="Enter Employee Name"
                    android:visibility="@{vm.canAddEmployeeName ? View.VISIBLE : View.GONE}"/>


                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/adhoc_employee_details"
                    android:visibility="gone"
                    android:orientation="vertical">
                    <EditText
                        android:layout_marginTop="@dimen/_4sdp"
                        android:id="@+id/et_adhoc_emp_regNo"
                        android:layout_width="@dimen/_150sdp"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:hint="Enter employee Reg No"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_height="?actionBarSize" />

                    <EditText
                        android:layout_marginTop="@dimen/_4sdp"
                        android:id="@+id/et_adhoc_emp_name"
                        android:layout_width="@dimen/_150sdp"
                        android:hint="Enter employee name"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_height="?actionBarSize" />

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:gravity="right"
                        android:layout_gravity="end">



                        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/btn_adhoc_emp"
                            android:layout_marginLeft="@dimen/_8sdp"
                            android:layout_marginTop="@dimen/_2sdp"
                            android:visibility="gone"
                            android:layout_marginRight="@dimen/_8sdp"
                            app:backgroundTint="@color/red"
                            android:layout_gravity="bottom|end"
                            app:tint="@color/colorWhite"
                            android:text="add"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:textStyle="bold" />

<!--                        android:onClick="@{vm::onAddAdhocEmpClicked}"-->

                        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/_8sdp"
                            android:layout_marginTop="@dimen/_2sdp"

                            android:layout_marginRight="@dimen/_8sdp"
                            android:alpha="@{vm.addEmpLoading ? 0.3f : 1f}"
                            android:clickable="@{vm.addEmpLoading ? false : true}"
                            android:onClick="@{vm::onAddClicked}"
                            app:backgroundTint="@color/red"
                            android:layout_gravity="bottom|end"
                            app:tint="@color/colorWhite"
                            android:text="@{vm.isAddVisual ? `Add` : `Search`}"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:textStyle="bold" />
                    </androidx.appcompat.widget.LinearLayoutCompat>


                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.core.widget.ContentLoadingProgressBar
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:visibility="@{vm.addEmpLoading ? View.VISIBLE : View.GONE}" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>