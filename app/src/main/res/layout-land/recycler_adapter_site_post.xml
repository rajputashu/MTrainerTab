<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>

        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.models.SpiTableDetailsResponse.SpiTableDetailsData"/>
        <import type="android.view.View"/>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.spi.SpiViewModel" />
    </data>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:layout_marginLeft="@dimen/_8sdp"
            android:layout_marginRight="@dimen/_8sdp"
            android:layout_marginTop="0.5dp"
            android:layout_marginBottom="0.5dp"
            android:weightSum="8"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/sl_no"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight=".5"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp"
                android:text="01"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_customer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1.3"
                android:textAlignment="center"
                android:singleLine="false"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp"
                android:text="@{adapterItem.customerName}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_customerId"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:singleLine="false"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp"
                android:text="@{adapterItem.unitCode}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_branch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:layout_weight="1.5"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp"
                android:text="@{adapterItem.branchName}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_type"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:gravity="center"
                android:text="@{adapterItem.type}"
                android:textSize="@dimen/_8ssp" />
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:text="@{adapterItem.Status}"
                android:gravity="center"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_lastupdate"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="LastUpdated"
                android:gravity="center"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="@dimen/_22sdp"
                android:id="@+id/tv_view"
                android:drawableTint="@color/black"
                android:layout_weight="0.6"
                android:drawableRight="@drawable/ic_keyboard_arrow_right_yellow_800_48dp" />



        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>
</layout>