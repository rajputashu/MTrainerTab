<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.models.EmployeeReportsResponse" />
        <import type="android.view.View"/>
    </data>


    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:layout_marginLeft="@dimen/_9sdp"
            android:layout_marginRight="@dimen/_8sdp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="1.5dp"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="130dp"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:singleLine="false"
                android:id="@+id/tv_doj"
                android:textColor="@color/black"
                android:textSize="15sp" />
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="160dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{adapterItem.zoneName}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="180dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.regionName)}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.branchName)}"/>
            <!--
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:layout_weight="0.8"
                            android:textAlignment="center"
                            android:id="@+id/tvpresentdayaname"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_5ssp"
                            android:text="@{String.valueOf(adapterItem.presentDays)}"/>
            -->

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.employeeName)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.employeeNo)}"/>

            <!--
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:layout_weight="1"
                            android:textAlignment="center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_5ssp"
                            android:text="@{String.valueOf(adapterItem.vanTrainingKM)}"/>
            -->

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.primaryContactNo)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.siteName)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:text="@{String.valueOf(adapterItem.isLogin)}"
                android:textStyle="bold"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:text="@{String.valueOf(adapterItem.courseStatus)}"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="16sp" />


        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>

</layout>