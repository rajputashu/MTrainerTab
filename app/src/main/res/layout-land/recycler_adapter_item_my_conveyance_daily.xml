<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.models.ConveyanceDailyData" />
        <import type="android.view.View"/>
    </data>


    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginBottom="1.5dp"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textAlignment="center"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{adapterItem.trainerName}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginEnd="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{adapterItem.employeeNo}"/>
            <!--<androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="0.6"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{String.valueOf(adapterItem.year)}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="0.8"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{String.valueOf(adapterItem.monthName)}"/>-->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:textAlignment="center"
                android:layout_marginEnd="@dimen/_1sdp"
                android:id="@+id/tvpresentdayaname"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.dayName)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="0.8"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:gravity="center"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.date)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="0.8"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginEnd="@dimen/_1sdp"
                android:text="@{String.valueOf(adapterItem.totalTask)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:gravity="center"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.totalDistanceKM)}"/>

            <!--
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:layout_weight="1"
                            android:textAlignment="center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_5ssp"
                            android:text="@{String.valueOf(adapterItem.vanTrainingKM)}"/>
            -->

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textSize="15sp"
                android:text="@{String.valueOf(adapterItem.otherDeductionKM)}"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="0.5"
                android:gravity="center"
                android:textStyle="bold"
                android:id="@+id/onclick"
                android:layout_marginEnd="@dimen/_1sdp"
                android:textAlignment="center"
                android:textColor="@color/red"
                android:textSize="16sp"
                android:text="view"/>



        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>

</layout>