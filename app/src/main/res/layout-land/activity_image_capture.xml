<?xml version="1.0" encoding="UTF-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.trainingimages.TrainingImageViewModel" />
    </data>


    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/flLiveImage"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_200sdp">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/tbPreTraining"
                    android:layout_width="match_parent"
                    android:layout_height="?actionBarSize"
                    android:gravity="center"
                    android:textAlignment="center"
                    app:layout_scrollFlags="snap"
                    app:title=" ">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.SwitchCompat
                            toggleListener="@{vm.toggleListener}"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_margin="@dimen/_8sdp"
                            android:text="@{vm.pictureType == 2 ? `Training Picture  ` : `SPI Image  `}" />
                    </LinearLayout>
                </androidx.appcompat.widget.Toolbar>

                <com.otaliastudios.zoom.ZoomImageView
                    android:id="@+id/imagePhoto1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="?actionBarSize"
                    android:scrollbars="vertical|horizontal"
                    app:alignment="center"
                    app:animationDuration="280"
                    app:flingEnabled="true"
                    app:horizontalPanEnabled="true"
                    app:maxZoom="2.5"
                    app:maxZoomType="zoom"
                    app:minZoom="0.7"
                    app:minZoomType="zoom"
                    app:oneFingerScrollEnabled="true"
                    app:overPinchable="true"
                    app:overScrollHorizontal="true"
                    app:overScrollVertical="true"
                    app:scrollEnabled="true"
                    app:threeFingersScrollEnabled="true"
                    app:transformation="centerInside"
                    app:transformationGravity="auto"
                    app:twoFingersScrollEnabled="true"
                    app:verticalPanEnabled="true"
                    app:zoomEnabled="true" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/takePhotoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TAKE PHOTO"
                    android:textColor="@color/textColorBlackBold"
                    android:textSize="@dimen/_20ssp" />

                <ImageView
                    android:id="@+id/fabCapture"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|bottom"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:backgroundTint="@color/red"
                    app:backgroundTint="@color/colorLightRed"
                    app:srcCompat="@drawable/ic_camera" />
            </FrameLayout>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/chipGroupPhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/flLiveImage"
                android:background="@color/colorWhite"
                android:orientation="horizontal">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/post_container"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_marginTop="@dimen/_14sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_marginBottom="@dimen/_16sdp"
                        android:animationCache="true"
                        android:scrollbars="horizontal"
                        android:theme="@style/Theme.MaterialComponents.Light"
                        app:singleLine="true"
                        app:singleSelection="true" />
                </HorizontalScrollView>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/gridview_picture"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/chipGroupPhoto"
                android:layout_marginTop="39dp"
                android:background="@color/colorWhite"
                android:paddingTop="10dp"
                android:scrollbarStyle="outsideInset"
                android:scrollbars="horizontal"
                android:smoothScrollbar="true"
                app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior" />

        </RelativeLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/flButtonPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="@dimen/_16sdp"
            app:backgroundTint="@color/red"
            app:layout_anchorGravity="bottom|right|end"
            app:srcCompat="@drawable/ic_arrow_forward"
            app:tint="@color/colorWhite" />

        <androidx.core.widget.ContentLoadingProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="@{vm.isLoading}" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>