<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.db.entities.AttendanceEntity" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_20sdp"
        android:background="@color/alpha_header"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/header_title_textview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="@dimen/_18sdp"
            android:text="@{adapterItem.header}"
            android:textColor="@color/alpha_title"
            android:textSize="@dimen/_7ssp"
            android:textStyle="bold" />

    </LinearLayout>
</layout>