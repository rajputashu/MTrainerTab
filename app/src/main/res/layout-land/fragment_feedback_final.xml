<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <import type="android.view.View"/>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.feedback.FeedbackFinalViewModel" />
    </data>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/DarkBlue"
        android:orientation="vertical">
        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="@color/colorWhite"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginLeft="@dimen/_15sdp"
            android:text="CLIENT MODE"/>



        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_15sdp"
            app:cardCornerRadius="@dimen/_6sdp"
            android:background="@color/colorWhite">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OKAY Experience"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_gravity="center_horizontal"
                    android:textSize="@dimen/_12ssp"
                    android:textColor="@color/black"
                    android:id="@+id/rating_header"/>

                <androidx.appcompat.widget.AppCompatRatingBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:isIndicator="true"
                    android:layout_gravity="center_horizontal"
                    android:progressTint="#ffc107"
                    android:clickable="false"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:id="@+id/feedback_ratting_show"/>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/_8sdp"
                        android:text="ADD REMARKS"
                        android:visibility="@{vm.isDtss ? View.VISIBLE : View.GONE}"
                        android:layout_gravity="center_horizontal"/>
                    <EditText
                        android:id="@+id/feedback_remarks"
                        android:gravity="start"
                        android:padding="@dimen/_8sdp"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_60sdp"
                        android:layout_margin="@dimen/_8sdp"
                        android:inputType="textMultiLine"
                        android:scrollbars="vertical"
                        android:visibility="@{vm.isDtss ? View.VISIBLE : View.GONE}"
                        android:background="@drawable/rectangle_red"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:visibility="@{vm.isDtss ? View.GONE : View.VISIBLE}"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_9sdp"
                        android:text="Why wasn’t it a great experience?"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textSize="@dimen/_10ssp"
                        android:textColor="@color/black"
                        android:id="@+id/rating_question_header"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:visibility="@{vm.isDtss ? View.GONE : View.VISIBLE}"
                        app:setFeedbackFinalRecyclerAdapter="@{vm.feedbackFinalRecylerAdapter}"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</layout>