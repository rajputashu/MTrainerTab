<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" >
        <shape>
            <gradient
                android:startColor="#f2f2f2"
                android:centerColor="#f2f2f2"
                android:endColor="#f2f2f2"
                android:angle="270" />
            <stroke
                android:width="1dp"
                android:color="#cacaca" />
            <corners
                android:radius="0dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#cacaca"
                android:centerColor="#e7e5e5"
                android:endColor="#cacaca"
                android:angle="270" />
            <stroke
                android:width="0.5dp"
                android:color="#cacaca" />
            <corners
                android:radius="0dp"
                />
        </shape>
    </item>
</selector>