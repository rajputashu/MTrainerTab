<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" >
        <shape>
            <gradient
                android:startColor="#ececec"
                android:centerColor="#ececec"
                android:endColor="#ececec"
                android:angle="270" />
            <stroke
                android:width="1dp"
                android:color="#fafafa" />
            <corners
                android:radius="0dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#ececec"
                android:centerColor="#fafafa"
                android:endColor="#ececec"
                android:angle="270" />
            <stroke
                android:width="0.5dp"
                android:color="#cacaca" />
            <corners
                android:radius="0dp"
                />
        </shape>
    </item>
</selector>