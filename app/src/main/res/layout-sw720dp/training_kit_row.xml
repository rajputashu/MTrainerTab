<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/relative_trainingkit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/rectangle_red"
            android:paddingBottom="20dp"
            android:paddingTop="@dimen/_15sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imageicon"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_alignParentStart="true"
                android:paddingStart="@dimen/_15sdp"
                android:src="@drawable/ic_slideshow_grey_700_36dp"
                tools:ignore="ContentDescription,RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/fireandsafety"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageicon"
                android:paddingStart="@dimen/_15sdp"
                android:text="fire and safety"
                android:textAllCaps="true"
                android:textColor="@color/colorLightRed"
                android:textSize="@dimen/_10ssp"
                android:textStyle="bold"
                tools:ignore="RelativeOverlap,RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/fireandsafety"
                android:layout_toEndOf="@id/imageicon"
                android:paddingStart="@dimen/_15sdp"
                android:paddingTop="8dp"
                android:visibility="gone"
                android:id="@+id/count"
                android:text="24 SLIDES/40 MINUTES"
                android:textSize="13sp"
                tools:ignore="HardcodedText,RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_30sdp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_right_arrow"
                android:contentDescription="TODO"
                tools:ignore="ContentDescription,HardcodedText" />


        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/relative_trainingkit1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="10dp"
            android:background="@drawable/rectangle_red"
            android:paddingBottom="20dp"
            android:paddingTop="@dimen/_15sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imageicon1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:paddingStart="@dimen/_15sdp"
                android:src="@drawable/ic_slideshow_grey_700_36dp"
                tools:ignore="ContentDescription,RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/fireandsafety1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageicon1"
                android:paddingStart="@dimen/_15sdp"
                android:text="INDUSTRIAL ELECTRICAL EQUIPMENTS"
                android:textColor="@color/colorLightRed"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:ignore="RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/fireandsafety1"
                android:layout_toEndOf="@id/imageicon1"
                android:paddingStart="@dimen/_15sdp"
                android:paddingTop="8dp"
                android:text="25 MINUTES"
                android:textSize="13sp"
                tools:ignore="RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/fireandsafety1"
                android:src="@drawable/ic_right_arrow"
                tools:ignore="ContentDescription" />

        </RelativeLayout>

    </androidx.appcompat.widget.LinearLayoutCompat>


</layout>