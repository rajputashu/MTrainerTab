<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.starttraining.StartTrainingViewModel" />

    </data>


    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tbStartTraining"
                android:layout_width="match_parent"
                android:layout_height="?actionBarSize"
                app:layout_scrollFlags="snap"
                app:title=" ">

                <TextView
                    android:id="@+id/toolbar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Start Training"
                    android:textColor="@color/textColorBlackBold"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/videosIcon"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_gravity="center|end"
                    android:src="@drawable/ic_video" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:layout_gravity="center|end"
                    android:background="@color/grey" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/onlineTrainingCourseButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:onClick="@{vm.onViewClick}"
                    android:layout_gravity="center|end"
                    app:srcCompat="@drawable/ic_online_training" />


            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/backgroudGray2"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

            <include
                android:id="@+id/includeTimeSpent"
                layout="@layout/include_layout_time_spent"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_24sdp"
                android:layout_alignParentTop="true" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llInstakart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/includeTimeSpent"
                android:layout_marginTop="0dp"
                android:background="@color/colorWhite"
                android:orientation="vertical"
                android:weightSum="2">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/_10sdp"
                    android:paddingEnd="@dimen/_16sdp"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_6sdp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_1sdp"
                        android:layout_weight="1"
                        android:text="@{vm.unitName}"
                        android:textColor="@color/textColorBlackBold"
                        android:textSize="@dimen/_9ssp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/training_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/_4sdp"
                        android:textColor="@color/textColorBlackBold"
                        android:textSize="@dimen/_12ssp" />

                    <!--<View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/_6sdp"
                        android:layout_marginEnd="@dimen/_6sdp"
                        android:background="@color/grey" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/onlineTrainingCourseButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="@{vm.onViewClick}"
                        android:tint="@color/blue"
                        app:srcCompat="@drawable/ic_online_courses" />
-->
                </androidx.appcompat.widget.LinearLayoutCompat>


                <!--<LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/_16sdp"
                    android:layout_marginRight="@dimen/_16sdp"
                    android:layout_marginBottom="@dimen/_16sdp"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:layout_marginBottom="@dimen/_4sdp"
                        android:text="PLANNED TRIANING TIME"
                        android:textColor="@color/colorTextGrey"
                        android:textSize="@dimen/_12ssp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{vm.plannedTime}"
                        android:textColor="@color/textColorBlackBold"
                        android:textSize="@dimen/_12ssp" />

                </LinearLayout>-->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_8sdp"
                    android:background="#e0e7ee" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedTrainingAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/llInstakart"
                android:layout_marginTop="0dp">


                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/llTrainingAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/llInstakart"
                        android:background="@color/colorWhite"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/_14sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:text="@string/training_actions"
                            android:textColor="@color/textColorBlackBold"
                            android:textSize="@dimen/_9ssp"
                            android:textStyle="bold" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/_12sdp"
                            app:adapterFilter="@{vm.companyID}"
                            app:navigationRecyclerAdapter="@{vm.navigationRecyclerAdapter}"
                            app:navigationViewListeners="@{vm.viewListeners}" />


                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:id="@+id/feedback_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/_16sdp"
                            android:layout_marginTop="@dimen/_12ssp"
                            android:layout_marginRight="@dimen/_16sdp"
                            android:layout_marginBottom="@dimen/_12ssp"
                            android:background="@drawable/less_rounded_border"
                            android:orientation="horizontal"
                            android:visibility="@{vm.role.equals(`Training Champ`) || vm.role.equals(`Unit Commander`)? View.GONE : View.VISIBLE}"
                            android:weightSum="1.5">

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/_12sdp"
                                android:layout_marginTop="@dimen/_5sdp"
                                android:layout_marginBottom="@dimen/_7sdp"
                                android:layout_weight="0.5"
                                android:orientation="vertical"
                                android:weightSum="2">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/client_feedback"
                                    android:textColor="@color/textColorBlackBold"
                                    android:textSize="@dimen/_8ssp"
                                    android:textStyle="bold" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Start a training to obtain feedback"
                                    android:textColor="@color/colorTextGrey"
                                    android:textSize="@dimen/_7ssp" />

                            </androidx.appcompat.widget.LinearLayoutCompat>

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_gravity="center"
                                android:layout_weight=".6"
                                android:drawablePadding="@dimen/_4sdp"
                                app:srcCompat="@drawable/ic_right_arrow" />


                        </androidx.appcompat.widget.LinearLayoutCompat>
                        <!--this for after getting feed back we need add-->

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:id="@+id/after_feedback_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/_16sdp"
                            android:background="@drawable/less_rounded_border"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:weightSum="1.5">

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/_12sdp"
                                android:layout_marginTop="@dimen/_7sdp"
                                android:layout_marginBottom="@dimen/_7sdp"
                                android:layout_weight="0.3"
                                android:orientation="vertical"
                                android:weightSum="2">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/client_feedback"
                                    android:textColor="@color/textColorBlackBold"
                                    android:textSize="@dimen/_10ssp"
                                    android:textStyle="bold" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/after_feedback_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Feedback obtained"
                                    android:textSize="@dimen/_9ssp" />
                            </androidx.appcompat.widget.LinearLayoutCompat>


                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/after_feedback_rating"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginRight="@dimen/_75sdp"
                                android:layout_weight="1"
                                android:drawableLeft="@drawable/ic_orange_start1"
                                android:drawableRight="@drawable/ic_completed1"
                                android:drawablePadding="@dimen/_4sdp"
                                android:gravity="center"
                                android:text="4/5"
                                android:textColor="@color/textColorBlackBold"
                                android:textSize="@dimen/_10ssp" />
                        </androidx.appcompat.widget.LinearLayoutCompat>


                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="600dp"
                        android:layout_height="300dp"
                        android:layout_gravity="center"
                        android:layout_marginLeft="30dp"
                        android:layout_marginTop="40dp"
                        android:layout_marginRight="30dp"
                        android:layout_marginBottom="10dp">

                        <fragment
                            android:id="@+id/map"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            app:layout_constraintTop_toTopOf="parent" />

                        <Button
                            android:id="@+id/btnRefresh"
                            android:layout_width="120dp"
                            android:layout_height="40dp"
                            android:layout_margin="20dp"
                            android:text="Refresh"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            app:backgroundTint="@color/red"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            app:rippleColor="@color/white" />

                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/llTrainingCoverage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:background="@color/backgroudGray2"
                        android:orientation="vertical">


                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginBottom="120dp"
                            android:orientation="vertical">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/_16sdp"
                                android:layout_marginTop="@dimen/_12sdp"
                                android:layout_marginRight="@dimen/_16sdp"
                                android:layout_marginBottom="@dimen/_6sdp"
                                app:cardCornerRadius="@dimen/_8sdp">

                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/_10sdp"
                                    android:layout_marginTop="@dimen/_7sdp"
                                    android:layout_marginRight="@dimen/_10sdp"
                                    android:layout_marginBottom="@dimen/_5sdp"
                                    android:orientation="horizontal"
                                    android:weightSum="@{vm.companyID.equals(`1`) || vm.companyID.equals(`4`) || vm.companyID.equals(`8`) ? 2 : 3}">

                                    <androidx.appcompat.widget.LinearLayoutCompat
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:weightSum="2">

                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:id="@+id/attendence_summary"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center_horizontal"
                                            android:layout_marginBottom="@dimen/_4sdp"
                                            android:layout_weight="1"
                                            android:text="@{vm.selectedEmployee + `/` + vm.totalEmployee}"
                                            android:textColor="@color/textColorBlackBold"
                                            android:textSize="@dimen/_8ssp"
                                            android:textStyle="bold" />

                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center_horizontal"
                                            android:layout_weight="1"
                                            android:text="Attendance"
                                            android:textColor="@color/colorTextGrey"
                                            android:textSize="@dimen/_6ssp" />


                                    </androidx.appcompat.widget.LinearLayoutCompat>

                                    <View
                                        android:layout_width="@dimen/_1sdp"
                                        android:layout_height="match_parent"
                                        android:background="@color/colorLightGrey" />

                                    <androidx.appcompat.widget.LinearLayoutCompat
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="@dimen/_12sdp"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:visibility="@{vm.companyID.equals(`1`) || vm.companyID.equals(`4`) || vm.companyID.equals(`8`) ? View.GONE : View.VISIBLE}"
                                        android:weightSum="2">

                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:id="@+id/post_summary"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center_horizontal"
                                            android:layout_marginBottom="@dimen/_4sdp"
                                            android:layout_weight="1"
                                            android:text="@{vm.selectedPost + `/` + vm.totalPost}"
                                            android:textColor="@color/textColorBlackBold"
                                            android:textSize="@dimen/_8ssp"
                                            android:textStyle="bold" />

                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center_horizontal"
                                            android:layout_weight="1"
                                            android:gravity="center"
                                            android:text="Posts"
                                            android:textColor="@color/colorTextGrey"
                                            android:textSize="@dimen/_6ssp" />


                                    </androidx.appcompat.widget.LinearLayoutCompat>

                                    <View
                                        android:layout_width="@dimen/_1sdp"
                                        android:layout_height="match_parent"
                                        android:background="@color/colorLightGrey"
                                        android:visibility="@{vm.companyID.equals(`1`) || vm.companyID.equals(`4`) || vm.companyID.equals(`8`) ? View.GONE : View.VISIBLE}" />

                                    <androidx.appcompat.widget.LinearLayoutCompat
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="@dimen/_12sdp"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:weightSum="2">

                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:id="@+id/topic_summary"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center_horizontal"
                                            android:layout_marginBottom="@dimen/_4sdp"
                                            android:layout_weight="1"
                                            android:text="@{vm.role.equals(`Training Champ`) || vm.role.equals(`Unit Commander`) ? String.valueOf(vm.selectedTopic+vm.selectedAdhocTopic): String.valueOf(vm.selectedTopic+vm.selectedAdhocTopic) + `/` + vm.totalTopic}"
                                            android:textColor="@color/textColorBlackBold"
                                            android:textSize="@dimen/_8ssp"
                                            android:textStyle="bold" />

                                        <androidx.appcompat.widget.AppCompatTextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center_horizontal"
                                            android:layout_marginBottom="@dimen/_6sdp"
                                            android:layout_weight="1"
                                            android:gravity="center"
                                            android:text="Topics"
                                            android:textColor="@color/colorTextGrey"
                                            android:textSize="@dimen/_6ssp" />


                                    </androidx.appcompat.widget.LinearLayoutCompat>
                                </androidx.appcompat.widget.LinearLayoutCompat>


                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_131sdp"
                                android:layout_marginLeft="@dimen/_16sdp"
                                android:layout_marginRight="@dimen/_16sdp"
                                android:layout_marginBottom="@dimen/_8sdp"
                                android:visibility="gone"
                                app:cardCornerRadius="@dimen/_10sdp">


                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/_12sdp"
                                    android:layout_marginTop="@dimen/_12sdp"
                                    android:text="Training Coverage - 06"
                                    android:textColor="@color/textColorBlackBold"
                                    android:textSize="@dimen/_7ssp"
                                    android:textStyle="bold" />

                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/_16sdp"
                                    android:layout_marginTop="@dimen/_45sdp"
                                    card_view:cardCornerRadius="25dp"
                                    card_view:cardPreventCornerOverlap="false">

                                    <com.droidcommons.views.roundedimageview.RoundedImageView
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_mtrainer_white"
                                        app:riv_corner_radius="@dimen/_8sdp" />
                                </androidx.cardview.widget.CardView>

                            </androidx.cardview.widget.CardView>


                        </androidx.appcompat.widget.LinearLayoutCompat>


                    </androidx.appcompat.widget.LinearLayoutCompat>


                </androidx.appcompat.widget.LinearLayoutCompat>


            </androidx.core.widget.NestedScrollView>


        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/training_done_btn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_35sdp"
            android:layout_gravity="bottom"
            android:background="@color/red"
            android:onClick="@{vm::onClickSubmitReport}"
            android:text="COMPLETE TRAINING"
            android:textColor="@color/colorWhite"
            android:textSize="@dimen/_7ssp"
            android:textStyle="bold" />

        <androidx.core.widget.ContentLoadingProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="@{vm.isLoading}" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>