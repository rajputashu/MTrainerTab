<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.models.SpiBasicInfoResponse.SpiBasicInfoDetailsData"/>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.spi.draftspi.DraftSpiViewModel" />
        <import type="android.view.View"/>
    </data>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_2sdp"
        android:background="@color/white"
        android:orientation="vertical">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:id="@+id/ll_header"
            android:layout_height="@dimen/_35sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_4sdp"
            android:weightSum="3"
            android:background="@drawable/rectangle_border"
            android:layout_marginLeft="@dimen/_10sdp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/sl_no"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_weight=".1"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp"
                android:text="01"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/post_name"
                android:layout_width="@dimen/_0sdp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1.6"

                android:textAlignment="center"
                android:singleLine="false"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_8ssp"
                android:text="Main Gate"/>

            <FrameLayout
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:layout_marginLeft="@dimen/_5sdp"
                android:id="@+id/flImage">
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/take_mount_image"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_gravity="center|bottom"
                    android:layout_marginBottom="@dimen/_3sdp"
                    app:backgroundTint="@color/blue"
                    android:background="@color/blue"

                   app:tint="@color/white"
                    app:srcCompat="@drawable/ic_add_black" />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/spi_img1"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:layout_marginLeft="@dimen/_20sdp"
                    android:gravity="center"
                    android:layout_weight=".5" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/spi_img2"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:visibility="gone"
                    android:gravity="center"
                    android:layout_weight=".5" />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/spi_img3"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:visibility="gone"
                    android:gravity="center"
                    android:layout_weight=".5" />

            </FrameLayout>


        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</layout>