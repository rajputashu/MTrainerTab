                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/storke_bg_white" />

                <Spinner
                    android:id="@+id/vS_dp_disbtype"
                    style="@style/SpinnerTheme1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
