<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@color/white"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingEnd="@dimen/_24sdp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusable="true"
            android:paddingBottom="@dimen/_24sdp">
            
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="27dp"
                android:layout_marginTop="16dp"
                android:text="Edit Unit"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_selCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp"
                android:text="Unit Code"
                app:layout_constraintEnd_toStartOf="@+id/vT_dp_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/vT_dp_title" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_selsubCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Unit Name"
                app:layout_constraintStart_toStartOf="@+id/rt1_spncatstatus"
                app:layout_constraintTop_toBottomOf="@+id/rt1_spncatstatus" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_prodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="SPI"
                app:layout_constraintStart_toStartOf="@+id/rt1_spnsubcatstatus"
                app:layout_constraintTop_toBottomOf="@+id/rt1_spnsubcatstatus" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/bt_dc_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="@dimen/_24sdp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp"
                android:background="@color/red"
                android:paddingLeft="@dimen/_22sdp"
                android:paddingRight="@dimen/_22sdp"
                android:text="Submit"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/sp_disbandedtype"
                app:layout_constraintTop_toBottomOf="@+id/sp_disbandedtype" />
            
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_spitobemounted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="SPI To Be Mounted"
                app:layout_constraintStart_toStartOf="@+id/rt1_spnproductstatus"
                app:layout_constraintTop_toBottomOf="@+id/rt1_spnproductstatus" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/et_spitobemounted"
                android:layout_width="338dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/storke_bg_white"
                android:digits="0123456789"
                android:ems="10"
                android:inputType="number"
                app:layout_constraintStart_toStartOf="@+id/vT_dp_spitobemounted"
                app:layout_constraintTop_toBottomOf="@+id/vT_dp_spitobemounted" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_spimounted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="SPI Mounted"
                app:layout_constraintStart_toStartOf="@+id/et_spitobemounted"
                app:layout_constraintTop_toBottomOf="@+id/et_spitobemounted" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/et_spimounted"
                android:layout_width="338dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/storke_bg_white"
                android:digits="0123456789"
                android:ems="10"
                android:inputType="number"
                app:layout_constraintStart_toStartOf="@+id/vT_dp_spimounted"
                app:layout_constraintTop_toBottomOf="@+id/vT_dp_spimounted" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_totalspicovered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Total SPI Post Covered"
                app:layout_constraintStart_toStartOf="@+id/et_spimounted"
                app:layout_constraintTop_toBottomOf="@+id/et_spimounted" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/et_totalspicovered"
                android:layout_width="338dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/storke_bg_white"
                android:digits="0123456789"
                android:ems="10"
                android:inputType="number"
                app:layout_constraintStart_toStartOf="@+id/vT_dp_totalspicovered"
                app:layout_constraintTop_toBottomOf="@+id/vT_dp_totalspicovered" />


