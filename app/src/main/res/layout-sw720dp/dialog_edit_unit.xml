            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_unittypetext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="UnitType"
                app:layout_constraintStart_toStartOf="@+id/et_totalspicovered"
                app:layout_constraintTop_toBottomOf="@+id/et_totalspicovered" />


            <RelativeLayout
                android:id="@+id/sp_unittype"
                android:layout_width="338dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="@+id/vT_dp_unittypetext"
                app:layout_constraintTop_toBottomOf="@+id/vT_dp_unittypetext">

                <View
                    android:id="@+id/view11"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/storke_bg_white" />

                <Spinner
                    android:id="@+id/vS_dp_unittype"
                    style="@style/SpinnerTheme1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginRight="8dp"
                    android:gravity="center"
                    android:theme="@style/MatchSpinnerTheme" />


            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/vT_dp_sectypetext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Sector Type"
                app:layout_constraintStart_toStartOf="@+id/sp_unittype"
                app:layout_constraintTop_toBottomOf="@+id/sp_unittype" />

