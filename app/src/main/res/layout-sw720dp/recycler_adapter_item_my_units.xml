<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="adapterItem"
            type="com.sisindia.ai.mtrainer.android.models.MyUnitsResponse.MyUnitsDetailList" />
        <import type="android.view.View"/>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.trainingcalendar.TrainingCalendarViewModel" />
    </data>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:layout_marginLeft="@dimen/_9sdp"
            android:layout_marginRight="@dimen/_8sdp"
            android:layout_marginTop="1.5dp"
            android:layout_marginBottom="1.5dp"
            android:weightSum="5"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"

                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey2"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.actualStartDateTime}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey2"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{adapterItem.actualEndDateTime}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey2"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{String.valueOf(adapterItem.gaurdTrained)}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey2"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{String.valueOf(adapterItem.assesmentDone)}"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_weight="1"
                android:textAlignment="center"
                android:background="@color/LightBlueGrey2"
                android:textColor="@color/black"
                android:textSize="@dimen/_5ssp"
                android:text="@{String.valueOf(adapterItem.noOfTopics)}"/>



        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>
</layout>