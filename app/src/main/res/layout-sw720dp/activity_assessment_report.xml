<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.assessment.AssessmentReportViewModel" />

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/tbAssessmentReport"
                    android:layout_width="match_parent"
                    android:layout_height="?actionBarSize"
                    app:layout_scrollFlags="snap"
                    app:title=" ">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/toolbar_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/assessment_report"
                        android:textColor="@color/textColorBlackBold"
                        android:textSize="@dimen/_16sdp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/assessmentReportSyncButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="Refresh"
                        android:drawableStart="@drawable/ic_syncing"
                        android:textColor="@color/textColorBlackBold"
                        android:textSize="@dimen/_10ssp"
                        android:onClick="@{vm::onViewClick}"
                        android:drawablePadding="@dimen/_2sdp"
                        android:layout_marginEnd="@dimen/_6sdp"
                        android:textStyle="bold" />

                </androidx.appcompat.widget.Toolbar>

            </com.google.android.material.appbar.AppBarLayout>

            <include
                android:id="@+id/includeTimeSpent"
                layout="@layout/include_layout_time_spent"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_24sdp"
                android:layout_alignParentTop="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_20sdp"
                android:background="@color/colorWhite"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="@color/header_blue1"
                    android:gravity="center"
                    android:text="Name"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_6ssp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/header_blue2"
                    android:gravity="center"
                    android:text="@string/string_course_topic_score"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_6ssp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/header_blue1"
                    android:gravity="center"
                    android:text="@string/string_assessment_score"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_6ssp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/header_blue2"
                    android:gravity="center"
                    android:text="@string/string_question_score"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_6ssp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/header_blue1"
                    android:gravity="center"
                    android:text="@string/string_score_obtained"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_6ssp" />

               <!-- <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.6"
                    android:background="@color/header_blue2"
                    android:gravity="center"
                    android:text="@string/string_result"
                    android:textColor="@color/colorWhite"
                    android:textSize="@dimen/_6ssp" />-->

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/flButtonTraining"
                app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"
                app:assessmentReportAdapter="@{vm.reportAdapter}" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.core.widget.ContentLoadingProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="@{vm.isLoading}" />

    </RelativeLayout>

</layout>