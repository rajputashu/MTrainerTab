<?xml version="1.0" encoding="utf-8"?>
<layout>
    <data>
        <variable
            name="vmviewmodel"
            type="com.sisindia.ai.mtrainer.android.features.myconveyance.MyconveyanceactivityViewmodel" />
    </data>
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".features.myconveyance.MyconvenceActivity">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:id="@+id/appbar1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tbTakeAttendance"
                android:layout_width="match_parent"
                app:title=" "
                android:layout_height="?actionBarSize"
                app:layout_scrollFlags="snap" >
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textColorBlackBold"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold"
                    android:text="My Conveyance"
                    android:layout_gravity="center"
                    android:id="@+id/toolbar_title" />
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:id="@+id/conveyancecontainer"
            android:layout_height="match_parent"/>

    </LinearLayout>

</layout>