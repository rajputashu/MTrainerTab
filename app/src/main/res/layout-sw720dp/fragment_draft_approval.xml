<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.sisindia.ai.mtrainer.android.features.spi.draftapproval.DraftApprovalViewModel" />
        <import type="android.view.View"/>
    </data>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/_2sdp"
        android:background="@color/white"
        android:orientation="vertical">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:id="@+id/ll_header"
            android:layout_height="@dimen/_35sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_marginLeft="@dimen/_10sdp"

            android:orientation="horizontal"
            android:background="@drawable/rectangle_corner_grey">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:layout_weight=".2"
                android:layout_marginLeft="@dimen/_10sdp"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/_4sdp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:text="@{vm.customer+`(`+vm.customerid+`)`+`-`+vm.type}"
                    android:textSize="@dimen/_8ssp"/>

            </androidx.appcompat.widget.LinearLayoutCompat>
            <!-- branchEntriesUnits="@{vm.branchList}"
             setSpinnerItemSelectorMyUnits="@{vm.viewListeners}"
        -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_weight=".5"

                android:gravity="center_horizontal"
                android:layout_gravity="center|end"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/_1sdp"
                    android:textAlignment="center"
                    android:singleLine="false"
                    android:textColor="@color/red"
                    android:textSize="@dimen/_8ssp"
                    android:text="@{`Status : ` +vm.status}" />
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_25sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:id="@+id/refresh_draft_approval"
                    android:tint="@color/LightdarkGrey"
                    android:layout_marginBottom="@dimen/_3sdp"
                    android:layout_gravity="end"
                    android:src="@drawable/ic_refresh_black_24dp" />
            </androidx.appcompat.widget.LinearLayoutCompat>


        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginLeft="@dimen/_10sdp"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:background="@drawable/rectangle_border"
            android:orientation="vertical">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/_2sdp"
                android:layout_marginLeft="@dimen/_1sdp"
                android:layout_marginRight="@dimen/_2sdp"
                android:layout_marginBottom="@dimen/_1sdp"

                android:background="@color/white"
                android:orientation="horizontal">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:background="@color/white"
                    android:orientation="vertical">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        android:text="  Basic Information"
                        android:drawableLeft="@drawable/ic_completed" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/grey"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        android:text=" 1 - Draft SPI"
                        android:drawableLeft="@drawable/ic_completed" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:textAlignment="center"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="@dimen/_8ssp"
                        android:text="  2 - Draft Approval"
                        android:drawableLeft="@drawable/ic_pending" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        android:text="  3 - Design"
                        android:drawableLeft="@drawable/ic_pending" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:textAlignment="center"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        android:text="  4 - Client Approval"
                        android:drawableLeft="@drawable/ic_pending" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textSize="@dimen/_8ssp"
                        android:text="  5 - Printing"
                        android:drawableLeft="@drawable/ic_pending" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textAlignment="center"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        android:text="  6 - Mounted"
                        android:drawableLeft="@drawable/ic_pending" />

                </androidx.appcompat.widget.LinearLayoutCompat>
                <View
                    android:layout_width="@dimen/_1sdp"
                    android:layout_height="match_parent"
                    android:background="@color/grey"/>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:background="@color/white"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle_squre_corner"
                        android:weightSum="4"
                        android:layout_marginLeft="@dimen/_8sdp"
                        android:layout_marginRight="@dimen/_8sdp"
                        android:layout_marginTop="0.5dp"
                        android:layout_marginBottom="0.5dp"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="@dimen/_8sdp"
                            android:layout_marginTop="@dimen/_2sdp"
                            android:layout_marginBottom="@dimen/_2sdp"
                            android:layout_weight=".5"
                            android:textAlignment="textStart"
                            android:gravity="center"
                            android:singleLine="false"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_8ssp"
                            android:text="Sr"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="@dimen/_1sdp"
                            android:layout_weight=".9"
                            android:textAlignment="center"
                            android:singleLine="false"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_8ssp"
                            android:text="Post"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:layout_weight="1.2"
                            android:textAlignment="center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_8ssp"
                            android:text="Status"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:layout_weight="1"
                            android:textAlignment="center"
                            android:layout_marginLeft="@dimen/_20sdp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_8ssp"
                            android:text="Remark"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_170sdp"
                        app:setDrafApprovalRecyclerAdapter="@{vm.draftApprovalRecyclerAdapter}"
                        android:orientation="vertical">

                    </androidx.recyclerview.widget.RecyclerView>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:background="@color/white"
                        android:layout_marginLeft="@dimen/_20sdp"
                        android:layout_gravity="center"
                        android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_Reupload"
                        android:layout_width="@dimen/_50sdp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:layout_marginRight="@dimen/_40sdp"
                        android:layout_gravity="end|bottom"
                        android:text="re-upload"
                        android:textSize="@dimen/_8ssp"
                        android:background="@color/red"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_approval"
                        android:layout_width="@dimen/_50sdp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:layout_marginRight="@dimen/_40sdp"
                        android:layout_gravity="end|bottom"
                        android:text="next"
                        android:textSize="@dimen/_8ssp"
                        android:background="@color/red"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>


            </androidx.appcompat.widget.LinearLayoutCompat>


        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>


</layout>